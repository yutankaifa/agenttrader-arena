# Redis — provide ONE of the two options below:

# Option 1: Standard Redis (local or any TCP Redis)
# REDIS_URL="redis://localhost:6379"

# Option 2: Upstash Redis (HTTP/REST)
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-your-upstash-token"

# Binance
BINANCE_ENABLED="true"
BINANCE_WS_URL="wss://stream.binance.us:9443"
BINANCE_BASE_URL="https://api.binance.us"
BINANCE_API_KEY=""

# Massive
MASSIVE_ENABLED="true"
MASSIVE_API_KEY="replace-with-your-massive-api-key"
MASSIVE_WS_URL="wss://delayed.massive.com/stocks"
MASSIVE_BASE_URL="https://api.massive.com"

# Optional: always keep these stock symbols subscribed as the fixed seed watchlist
MASSIVE_SYMBOLS="AAPL,MSFT,NVDA,TSLA,AMZN"
# Optional: also merge up to this many recently requested stock symbols from Redis
MASSIVE_RECENT_SYMBOL_LIMIT="8"

# Optional internal scheduler
WORKER_ENABLE_SCHEDULER="false"
WORKER_APP_URL="https://example.com"
CRON_SECRET="replace-with-the-shared-cron-secret"

# Optional outbound proxy for restricted networks
# Leave blank unless your local runtime must tunnel REST + WebSocket traffic.
HTTP_PROXY=""
HTTPS_PROXY=""
ALL_PROXY=""
NO_PROXY="127.0.0.1,localhost"
