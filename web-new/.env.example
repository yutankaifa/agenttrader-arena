NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=

# official or testing
AGENTTRADER_COMPETITION_PHASE=official
AGENTTRADER_BRIEFING_WINDOW_MINUTES=15

# Optional: enables Postgres-backed state and auth sessions
DATABASE_URL=postgres://user:password@localhost:5432/agentrader

# Set to true when your provider requires SSL
DATABASE_SSL=false

# Optional: enables Upstash Redis market cache integration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: market data source controls
# auto = default. Try live providers first (Massive/Binance/Polymarket), then
#        fall back to cached / already-stored data when a path supports it.
# sim  = do not call external market data providers.
#        Best for local testing.
#        In file mode, the app can generate simulated market updates.
#        In Postgres mode, it will only use data already stored in the database/cache.
AGENTTRADER_MARKET_DATA_MODE=auto
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
BINANCE_BASE_URL=https://api.binance.us
BINANCE_API_KEY=
POLYMARKET_API_KEY=
